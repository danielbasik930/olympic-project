  .insights-title { font-family: 'Playfair Display', serif; font-size: clamp(30px, 4vw, 52px); font-weight: 900; color: #fff; margin-bottom: 16px; }
  .insights-title em { color: var(--gold-light); font-style: italic; }
  .insights-desc { font-size: 16px; color: var(--silver); font-weight: 300; line-height: 1.7; }

  .insight-block { max-width: 1100px; margin: 0 auto 100px; display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: start; }
  .insight-block.reverse { grid-template-columns: 1.4fr 1fr; }
  .insight-block.reverse .insight-text { order: 2; }
  .insight-block.reverse .insight-viz { order: 1; }

  .insight-num { font-family: 'Playfair Display', serif; font-size: 90px; font-weight: 900; color: rgba(201,168,76,0.08); line-height: 1; margin-bottom: -16px; user-select: none; }
  .insight-tag { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 3px; color: var(--gold); text-transform: uppercase; margin-bottom: 12px; }
  .insight-headline { font-family: 'Playfair Display', serif; font-size: clamp(18px, 2.2vw, 28px); font-weight: 700; color: #fff; line-height: 1.25; margin-bottom: 20px; }
  .insight-body { font-size: 14.5px; line-height: 1.85; color: var(--silver); font-weight: 300; }
  .insight-body strong { color: #fff; font-weight: 600; }
  .insight-body p + p { margin-top: 14px; }
  .insight-finding { margin-top: 24px; padding: 14px 18px; border-left: 2px solid var(--gold); background: rgba(201,168,76,0.04); }
  .insight-finding-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 2px; color: var(--gold); text-transform: uppercase; margin-bottom: 6px; }
  .insight-finding p { font-size: 13px; color: var(--silver); line-height: 1.65; font-style: italic; }

  .viz-card { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.07); padding: 24px; }
  .viz-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; margin-bottom: 16px; }
  .chart-toggle { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
  .toggle-btn { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 1px; padding: 5px 12px; border: 1px solid rgba(255,255,255,0.12); background: transparent; color: var(--silver); cursor: pointer; text-transform: uppercase; transition: all 0.2s; }
  .toggle-btn.active { border-color: var(--gold); color: var(--gold); background: rgba(201,168,76,0.08); }
  .toggle-btn:hover { border-color: rgba(201,168,76,0.5); color: var(--gold-light); }

  #summary { max-width: 760px; margin: 0 auto; padding: 100px 40px; }
  .summary-title { font-family: 'Playfair Display', serif; font-size: clamp(26px, 4vw, 44px); font-weight: 700; color: var(--navy); margin-bottom: 14px; }
  .summary-title em { font-style: italic; color: var(--blue-mid); }
  .summary-lead { font-size: 19px; color: var(--body); font-weight: 300; line-height: 1.7; margin-bottom: 48px; font-style: italic; border-left: 3px solid var(--gold); padding-left: 24px; }
  .summary-findings { display: flex; flex-direction: column; gap: 28px; }
  .summary-item { display: grid; grid-template-columns: 44px 1fr; gap: 16px; align-items: start; }
  .summary-icon { width: 44px; height: 44px; background: var(--navy); border: 1px solid rgba(201,168,76,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .summary-item-title { font-size: 16px; font-weight: 600; color: var(--navy); margin-bottom: 5px; }
  .summary-item-text { font-size: 15px; color: var(--body); line-height: 1.75; font-weight: 300; }
  .section-divider { width: 60px; height: 2px; background: var(--gold); margin: 48px 0; }

  footer { background: var(--navy); padding: 40px; text-align: center; }
  .footer-rings { display: flex; justify-content: center; gap: 5px; align-items: center; margin-bottom: 20px; }
  .footer-ring { width: 18px; height: 18px; border-radius: 50%; border: 2.5px solid transparent; }
  .footer-ring:nth-child(1) { border-color: #0085C7; }
  .footer-ring:nth-child(2) { border-color: #F4C300; margin-top: 10px; }
  .footer-ring:nth-child(3) { border-color: #009F6B; }
  .footer-ring:nth-child(4) { border-color: #DF0024; margin-top: 10px; }
  .footer-ring:nth-child(5) { border-color: #F4C300; }
  .footer-text { font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 1px; color: var(--muted); line-height: 1.8; }
  .footer-text strong { color: var(--silver); }

  .tooltip { position: fixed; background: rgba(10,22,40,0.97); color: #fff; padding: 8px 12px; font-family: 'DM Mono', monospace; font-size: 11px; pointer-events: none; opacity: 0; transition: opacity 0.15s; border: 1px solid var(--gold); z-index: 1000; line-height: 1.6; }

  @keyframes fadeUp { from { opacity:0; transform: translateY(24px); } to { opacity:1; transform: translateY(0); } }
  .reveal { opacity:0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity:1; transform: translateY(0); }

  @media (max-width: 768px) {
    .insight-block, .insight-block.reverse { grid-template-columns: 1fr; }
    .insight-block.reverse .insight-text { order: 1; }
    .insight-block.reverse .insight-viz { order: 2; }
    .dataset-card { grid-template-columns: 1fr 1fr; }
    .hero-stats { gap: 20px; }
    #hero { padding: 80px 24px; }
    #intro, #summary { padding: 60px 24px; }
    #insights { padding: 60px 24px; }
