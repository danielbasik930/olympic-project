  <div class="hero-label">Introduction to Data Science &nbsp;·&nbsp; Reichman University &nbsp;·&nbsp; Midterm 2026</div>
  <h1 class="hero-title">120 Years of<br><em>Olympic History</em></h1>
  <p class="hero-subtitle">A Data Detective Investigation</p>

  <div class="hero-byline">
    <div class="hero-avatar">D</div>
    <div>
      <div class="hero-name">Daniel Tashtash</div>
      <div class="hero-role">Former Olympic Athlete &nbsp;·&nbsp; Windsurfer &nbsp;·&nbsp; Data Science Student</div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="hero-stat"><div class="hero-stat-num">70,000</div><div class="hero-stat-label">Athlete Records</div></div>
