  .personal-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25); padding: 6px 14px; margin-bottom: 28px; font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 1px; color: var(--gold-light); text-transform: uppercase; }

  .dataset-card { margin-top: 48px; background: var(--ice); border: 1px solid rgba(26,58,107,0.1); border-left: 3px solid var(--gold); padding: 24px 28px; display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .dcard-num { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--blue-mid); }
