  @keyframes ringPop { from { opacity: 0; transform: scale(0.4); } to { opacity: 1; transform: scale(1); } }

  #hero { min-height: 100vh; background: var(--navy); position: relative; display: flex; flex-direction: column; justify-content: center; overflow: hidden; padding: 80px 40px 80px; }
